{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "http://warble.ir:8000/XFeats.schema.json",
  "title": "XFeats Manifest Schema",
  "description": "Schema for project-agnostic SWIG binding transformation features (XFeats).",

  "type": "object",

  "required": ["$XFeats", "$Schema", "$Description", "xfeats"],

  "properties": {
    "$XFeats": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$",
      "description": "Version of the XFeats specification (semantic versioning)."
    },

    "$Schema": {
      "type": "string",
      "format": "uri",
      "description": "Canonical URI of the schema."
    },

    "$Description": {
      "type": "string",
      "minLength": 10,
      "description": "Human-readable description of the manifest."
    },

    "xfeats": {
      "type": "object",
      "description": "Mapping of language (or group) → list of XFeats.",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/xfeatList"
      }
    }
  },

  "additionalProperties": false,

  "$defs": {

    "xfeatList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/xfeat"
      }
    },

    "xfeat": {
      "type": "object",
      "required": ["name", "description", "swig_flags"],
      "additionalProperties": false,

      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "minLength": 3,
          "description": "Unique identifier for the XFeat (snake_case)."
        },

        "description": {
          "type": "string",
          "minLength": 20,
          "description": "Detailed explanation, including examples and behavior."
        },

        "swig_flags": {
          "type": "array",
          "description": "List of SWIG flags required to enable this feature.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },

        "implementation": {
          "type": "string",
          "minLength": 10,
          "description": "Instructions for implementing the XFeat in SWIG."
        },

        "category": {
          "type": "string",
          "enum": [
            "memory",
            "safety",
            "conversion",
            "idiomatic",
            "performance",
            "debugging",
            "api_design",
            "interoperability"
          ],
          "description": "Optional classification of the feature."
        },

        "targets": {
          "type": "array",
          "description": "Optional list of applicable languages.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },

        "conflicts_with": {
          "type": "array",
          "description": "List of XFeat names that conflict with this one.",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "uniqueItems": true
        },

        "requires": {
          "type": "array",
          "description": "List of XFeats required for this one (optional, discouraged but supported).",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "uniqueItems": true
        },

        "super": {
          "type": "boolean",
          "default": false,
          "description": "Marks this XFeat as a Super XFeat."
        },

        "composes": {
          "type": "array",
          "description": "List of XFeats composed into this Super XFeat.",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "uniqueItems": true
        },

        "since": {
          "type": "string",
          "pattern": "^v\\d+\\.\\d+\\.\\d+$",
          "description": "Version in which this XFeat was introduced."
        },

        "deprecated": {
          "type": "boolean",
          "default": false,
          "description": "Whether this XFeat is deprecated."
        },

        "notes": {
          "type": "string",
          "description": "Additional notes or caveats."
        }
      },

      "allOf": [
        {
          "if": {
            "properties": { "super": { "const": true } }
          },
          "then": {
            "required": ["composes"],
            "properties": {
              "composes": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "required": ["composes"]
          },
          "then": {
            "properties": {
              "super": { "const": true }
            }
          }
        }
      ]
    }
  }
}